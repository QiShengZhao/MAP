DATABASE_URL=postgresql+asyncpg://agent_runtime:agent_runtime@postgres:5432/agent_platform
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-in-production
OPENAI_API_KEY=sk-xxx
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agent-artifacts

# 沙箱：local（开发）| k8s（生产）
SANDBOX_BACKEND=local
SANDBOX_LOCAL_BASE_DIR=/tmp/agent-sandbox
SANDBOX_LOCAL_NO_NET=false

# 事件总线：redis（默认）| kafka
EVENT_BUS=redis
EVENT_SERIALIZATION=json
KAFKA_BOOTSTRAP=kafka:29092
SCHEMA_REGISTRY_URL=http://schema-registry:8081
KAFKA_RF=1

SANDBOX_IMAGE=agent-sandbox:latest
BROWSER_IMAGE=agent-browser:latest
ARTIFACT_SIDECAR_IMAGE=agent-sidecar:latest
INTERNAL_TOKEN=internal-secret
KUBE_IN_CLUSTER=false
ROUTE_STRATEGY=cost
MODEL_PRICING_JSON={"openai-default/gpt-4o":{"prompt":2.5,"completion":10.0}}
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
