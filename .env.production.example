# 全部值必须由密钥管理系统注入，禁止明文入库
ENV=production
JWT_KEYS={"k2025q3":"<32B+ random>","k2025q2":"<上一轮 key，留作验签过渡>"}
JWT_ACTIVE_KID=k2025q3
INTERNAL_TOKEN=<32B+ random>
SECURE_COOKIES=true
CORS_ORIGINS=["https://console.example.com"]
TRUSTED_HOSTS=["api.example.com"]
DATABASE_URL=postgresql+asyncpg://app:<pwd>@pg:5432/agent?ssl=require
REDIS_URL=rediss://:<pwd>@redis:6380/0
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_USERNAME=agent-platform
KAFKA_SASL_PASSWORD=<secret>
KAFKA_SSL_CAFILE=/etc/tls/kafka-ca.pem
KAFKA_RF=3
EVENT_BUS=kafka
EVENT_SERIALIZATION=avro
SCHEMA_REGISTRY_URL=https://schema-registry:8081
SANDBOX_BACKEND=k8s
STRIPE_API_KEY=<sk_live_...>
STRIPE_WEBHOOK_SECRET=<whsec_...>
